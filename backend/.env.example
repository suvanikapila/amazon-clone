# Database Configuration
# ========================

# Option 1: LOCAL MySQL Development
# Install MySQL locally and update these:
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=amazon_clone
DB_PORT=3306

# Option 2: Render/Railway Production
# Replace with your actual deployed database credentials:
# DB_HOST=gondola.proxy.rlwy.net
# DB_USER=root  
# DB_PASSWORD=your_render_password
# DB_NAME=railway
# DB_PORT=3306

# Server Port
PORT=5000

# For Production Deployment
# NODE_ENV=production
